{
  "id": "contextlake",
  "name": "ContextLake Toolkit",
  "description": "Volcengine Lake AI Service (LAS) Toolkit & TOS (S3 compatible) File Storage Utilities.",
  "skills": ["./skills"],
  "providerAuthEnvVars": {
    "contextlake": ["LAS_API_KEY", "LAS_REGION", "TOS_ACCESS_KEY", "TOS_SECRET_KEY"]
  },
  "uiHints": {
    "las": {
      "region": {
        "label": "LAS Region",
        "help": "LAS Region (e.g. cn-beijing). Defaults to cn-beijing."
      },
      "apiKey": {
        "label": "LAS API Key",
        "help": "Your Volcengine LAS API Key (fallback: LAS_API_KEY env var).",
        "sensitive": true,
        "placeholder": "..."
      }
    },
    "tos": {
      "endpoint": {
        "label": "TOS Endpoint",
        "help": "TOS API Endpoint (e.g. tos-cn-beijing.volces.com)"
      },
      "region": {
        "label": "TOS Region",
        "help": "TOS Region (e.g. cn-beijing)"
      },
      "accessKeyId": {
        "label": "TOS Access Key ID",
        "help": "Your Volcengine Access Key ID (fallback: TOS_ACCESS_KEY env var)."
      },
      "secretAccessKey": {
        "label": "TOS Secret Access Key",
        "help": "Your Volcengine Secret Access Key (fallback: TOS_SECRET_KEY env var).",
        "sensitive": true
      }
    }
  },
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "las": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "region": {
            "type": "string"
          },
          "apiKey": {
            "type": ["string", "object"]
          }
        }
      },
      "tos": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "endpoint": {
            "type": "string"
          },
          "region": {
            "type": "string"
          },
          "accessKeyId": {
            "type": ["string", "object"]
          },
          "secretAccessKey": {
            "type": ["string", "object"]
          }
        }
      }
    }
  }
}

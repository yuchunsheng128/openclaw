{
  "id": "las-toolkit",
  "name": "LAS Toolkit",
  "description": "Volcengine Lake AI Service (LAS) Toolkit",
  "skills": ["./skills"],
  "providerAuthEnvVars": {
    "las-toolkit": ["LAS_API_KEY", "LAS_REGION"]
  },
  "uiHints": {
    "las": {
      "region": {
        "label": "LAS Region",
        "help": "LAS Region (e.g. cn-beijing). Defaults to cn-beijing."
      },
      "apiKey": {
        "label": "LAS API Key",
        "help": "Your Volcengine LAS API Key (fallback: LAS_API_KEY env var).",
        "sensitive": true,
        "placeholder": "..."
      }
    }
  },
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "las": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "region": {
            "type": "string"
          },
          "apiKey": {
            "type": ["string", "object"]
          }
        }
      }
    }
  }
}
